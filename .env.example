# Required
GOOGLE_API_KEY=

# Model configuration
MODEL_NAME=gemini-2.5-flash
SCREENSHOT_ANALYSIS_MODEL=gemini-2.5-flash

# Retry behavior
TRANSIENT_RETRY_ATTEMPTS=3
TRANSIENT_RETRY_BASE_DELAY_SECONDS=5.0

# Optional observability
LOGFIRE_TOKEN=
LOGFIRE_SERVICE_NAME=auto-browser-demo2

# Screenshot and browser session storage
SCREENSHOT_DIR=logs/screenshots
ENABLE_SCREENSHOTS=true
ENABLE_SS_ANALYSIS=true
SCREENSHOT_FULL_PAGE=false
PLAYWRIGHT_USER_DATA_DIR=logs/playwright-user-data
